# Copy to .env and fill in. Do NOT commit the real .env.
#   cp .env.example .env

# --- Database (you invent these; the container creates a fresh DB) ---
DB_ROOT_PASSWORD=change_me_strong_root
DB_NAME=wordpress
DB_USER=wordpress_user
DB_PASSWORD=change_me_strong_db

# --- Must match the OLD site's wp-config.php $table_prefix EXACTLY ---
# Confirmed from gunduaafrica.com wp-config.php. Note the LEADING underscore.
# Tables in the dump are named _ifsldf_posts, _ifsldf_options, etc.
TABLE_PREFIX=_ifsldf_

# --- Site URL ---
# PREVIEW before DNS cutover (server IP + WordPress port):
#   SITE_URL=http://YOUR.SERVER.IP:5053
# After Nginx Proxy Manager + DNS cutover:
#   SITE_URL=https://gunduaafrica.com
SITE_URL=http://YOUR.SERVER.IP:5053

# NOTE: MySQL/MariaDB runs INSIDE the container on port 5054 and is published to
# the host on 5054 (so it never clashes with Webuzo's 3306). WordPress reaches it
# at 127.0.0.1:5054 internally — that's hardcoded in docker-compose.yml.
